# =============================================================================
# WIUT Graduation Yearbook — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# The public URL of your deployment (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret used to sign invitation tokens (generate with: openssl rand -hex 32)
INVITATION_SECRET=change-this-to-a-random-secret

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# The Supabase Storage bucket name for private media
# Default: "yearbook-media" (matches src/lib/storage/index.ts)
STORAGE_BUCKET_NAME=yearbook-media

# Signed URL expiry in seconds (default 3600 = 1 hour)
SIGNED_URL_EXPIRY_SECONDS=3600

# -----------------------------------------------------------------------------
# Email (optional — Supabase handles auth emails by default)
# If you want custom transactional emails, configure an SMTP provider here.
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=your-resend-api-key
# SMTP_FROM=noreply@wiut.uz

# -----------------------------------------------------------------------------
# Image Processing (optional)
# Sharp is used automatically in Next.js Image Optimization.
# No additional config required unless you self-host the image optimizer.
# -----------------------------------------------------------------------------

# =============================================================================
# Supabase Setup Checklist
# =============================================================================
# 1. Create a new Supabase project
# 2. Run migrations: supabase db push (or paste SQL from supabase/migrations/)
# 3. Create a private storage bucket named "yearbook-media"
#    - Go to Storage → New bucket → name: yearbook-media → Private ✓
# 4. Apply storage policies (see supabase/migrations/00001_initial_schema.sql)
# 5. Enable Email Auth in Supabase Dashboard → Authentication → Providers
# 6. Disable "Confirm email" for invite-only flow (optional)
# 7. Set Site URL in Auth → URL Configuration to NEXT_PUBLIC_APP_URL
# 8. Add http://localhost:3000/auth/callback to Redirect URLs
# 9. Seed the database: npx tsx scripts/seed.ts
# =============================================================================
